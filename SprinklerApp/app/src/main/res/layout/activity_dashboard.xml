<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Loading indicator – viditelny kym sa nenacitaju prve data z Firebase -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"/>

        <!-- Offline banner -->
        <TextView
            android:id="@+id/tvOfflineBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zariadenie offline — zobrazujú sa posledné známe dáta"
            android:textColor="#FF000000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="10dp"
            android:layout_marginBottom="12dp"
            android:background="#FFFBBF24"
            android:visibility="gone"/>

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ovládací panel zavlažovania"
            android:textColor="@color/accent_green"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="4dp"/>


        <!-- Sensor readings card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hodnoty senzorov"
                    android:textColor="@color/accent_green"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Teplota" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tvTemperature" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Vlhkosť vzduchu" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tvHumidity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Vlhkosť pôdy" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tvMoisture" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dážď" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tvRain" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Svetlo" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tvLight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Zavlažovač" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tvSprinklerState" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Riadok pre stav nadrze - plovakovy senzor na pine 4 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Nádrž na vodu" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tvWaterLow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Graph card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="História"
                    android:textColor="@color/accent_green"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingBottom="10dp"/>

                <!-- Selector buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:baselineAligned="false">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGraphTemp"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:text="Teplota"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginEnd="4dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGraphHumidity"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:text="Vlhkosť vzduchu"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginEnd="4dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGraphMoisture"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:text="Vlhkosť pôdy"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginEnd="4dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGraphRain"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:text="Dážď"
                        android:textSize="10sp"
                        android:gravity="center"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                </LinearLayout>

                <WebView
                    android:id="@+id/graphWebView"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Controls card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ovládanie"
                    android:textColor="@color/accent_green"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/tvModeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Režim: Automatický"
                    android:textColor="@color/accent_green"
                    android:textSize="13sp"
                    android:paddingBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAutoMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Auto režim: ZAP"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="10dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManualWater"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Manuálne zalievanie: VYP"
                    android:textColor="@color/text_primary"
                    android:enabled="false"
                    android:alpha="0.4"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
